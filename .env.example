# Polymarket API 配置
# 去 Polymarket Settings -> API Keys 获取
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_WALLET_ADDRESS=your_wallet_address_here

# BTC Up/Down 5m 市场 ID
# 从 Polymarket 官网获取具体的市场 ID
BTC_UPDOWN_MARKET_ID=

# 运行模式
# - paper_live: 持续运行的 4 小时 BTC 纸上交易
# - paper_replay: 旧的 5 分钟历史回放
TRADING_MODE=paper_live

# 交易参数
BET_AMOUNT=1              # 每次下注金额 (USDC)
PAPER_BET_AMOUNT=1        # 纸上交易单笔金额
MAX_BET_AMOUNT=1          # 单笔最大金额
MIN_PROBABILITY_DIFF=0.1  # 最小概率差 (10%) 才下单
PAPER_START_BALANCE=100   # 纸上交易起始余额
TAKE_PROFIT_PERCENT=0.18  # 止盈 18%
PAPER_MAX_ENTRY_PRICE=0.60
PAPER_TAKE_PROFIT_USD=1
PAPER_POLL_INTERVAL_SECONDS=30
PAPER_MAX_OPEN_POSITIONS=6
PAPER_WALLET_LABEL=LOCAL-SIM-100U

# 止损设置
STOP_LOSS_ENABLED=false
STOP_LOSS_PERCENT=0.10    # 亏损 10% 时止损
TIME_EXIT_SECONDS=45      # 收盘前 45 秒强制离场

# BTC 数据源 (binance 或 coingecko)
BTC_PRICE_SOURCE=binance

# AI 预测参数
AI_UP_THRESHOLD=0.02      # 涨超 0.02% 预测涨
AI_DOWN_THRESHOLD=-0.02   # 跌超 0.02% 预测跌
MA_PERIOD=5               # 移动平均周期
